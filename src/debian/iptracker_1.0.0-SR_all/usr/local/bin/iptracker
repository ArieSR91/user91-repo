#!/bin/bash

green='\033[1;92m'
white='\033[0;97m'
targeturl=$@


user_ip() {
    myip="$(curl -s ipinfo.io/ip)"
    target="${myip}"
    start_track
}

show_help() {
    echo -e " IP Tracker 1.0.0-SR
Usage: iptracker [target ip] [options]
      -u, --user       : Track your ip information
      -h, --help       : Show this help screen
      -v, --version    : Show the version

for more information visit: https://github.com/ArieSR91
"
}

show_version() {
    echo "1.0.0-SR"
}

start_track() {
    IPAD="$(curl -s ipinfo.io/${target}/ip)"
    HOST="$(curl -s ipinfo.io/${target}/hostname)"
    CITY="$(curl -s ipinfo.io/${target}/city)"
    REGN="$(curl -s ipinfo.io/${target}/region)"
    CNTR="$(curl -s ipinfo.io/${target}/country)"
    ORGS="$(curl -s ipinfo.io/${target}/org)"
    LOCT="$(curl -s ipinfo.io/${target}/loc)"
    TIMZ="$(curl -s ipinfo.io/${target}/timezone)"
    GMAP="http://www.google.com/maps/place/${LOCT}/@${LOCT},16z"
    RED=$(tput setaf 1)
    GREEN=$(tput setaf 2)
    col=$(tput cols)
    printf '%s%*s%s' "$RED" $col "<|=========================|"
    printf "$RED|=========================================|>\n$GREEN"
    figlet -tc IpTracker
    printf '%s%*s%s' "$RED" $col "<|=========================================|"
    printf "$RED|=========================|>\n"
    echo -e "$white Ip: $green${IPAD}\n$white Hostname: $green${HOST}\n$white ASN: $green${ORGS}\n$white City: $green${CITY}\n$white Region: $green${REGN}\n$white Country: $green${CNTR}\n$white Location: $green${LOCT}\n$white Timezone: $green${TIMZ}\n$white Google Map: $green${GMAP}"
    exit
}

case $1 in
    -u | --user)
        user_ip
        ;;
    -h | --help)
        show_help
        ;;
    -v | --version)
        show_version
        ;;
esac

target="${targeturl}"
start_track
