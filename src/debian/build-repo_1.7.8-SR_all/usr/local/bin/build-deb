#!/bin/bash

function build_deb() {
    if [ ! -d src ]; then
        echo -e "src folder not found. Move your package folder to src/(ostype) folder\nor type <build-deb source> to create default package"
        mkdir -p src/debian
        mkdir src/termux
        ## Termux
        if [ ! -d termux-deb ]; then
            mkdir -p termux-deb
        else
            if [ ! -d termux-deb/main ]; then
                mkdir -p termux-deb/main
            fi
        fi
        ## Debian Based
        if [ ! -d debian-deb ]; then
            mkdir -p debian-deb
        else
            if [ ! -d debian-deb/main ]; then
                mkdir -p debian-deb/main
            fi
        fi
        exit
    else
        read -p "OS Type: " linuxtype;
        files=$(ls -1 src/$linuxtype)
        select choice in ${files[@]}; do
            break
        done
        echo "${choice}"
        if [ ! -d "src/${linuxtype}/${choice}/DEBIAN" ]; then
            echo "Lets start to make your own project"
            echo "Run: build-deb source"
        else
            read -p "Will be put in the components folder: " compfold;
            debfold="${linuxtype}-deb"
            dpkg-deb --build "src/${linuxtype}/${choice}"
            mv src/${linuxtype}/${choice}.deb ${debfold}/${compfold}/
        fi
    fi
}

function build_source() {
    TERMUXSHEBANG="#!/data/data/com.termux/files/usr/bin/bash"
    DEBIANSHEBANG="#!/bin/bash"
    if [ -d src ]; then
        read -p "OS Type: " linuxtype;
        read -p "Package Name: " pkgname;
        read -p "Version: " versiondeb;
        read -p "Architecture: " archtype;
        read -p "Depends: " depend;
        read -p "Installed Size: " installsize;
        read -p "Descriptions: " description;
        read -p "Username: " username;
        read -p "Email: " useremail;
        read -p "Home Page: " homepage;
        if [ ! -d src/${linuxtype}/${pkgname}_${versiondeb}_${archtype}/DEBIAN ]; then
            mkdir -p src/${linuxtype}/${pkgname}_${versiondeb}_${archtype}/DEBIAN
        else
            chmod 755 src/${linuxtype}/${pkgname}_${versiondeb}_${archtype}/DEBIAN -R
            echo -e "Run: nano src/${linuxtype}/${pkgname}_${versiondeb}_${archtype}/usr/local/bin/(your binary)\nOr move your binary this folder"
            exit
        fi
        if [ "$linuxtype" == "termux" ]; then
            mkdir -p src/${linuxtype}/${pkgname}_${versiondeb}_${archtype}/data/data/com.termux/files/usr/bin
            echo "${TERMUXSHEBANG}" >> src/${linuxtype}/${pkgname}_${versiondeb}_${archtype}/DEBIAN/postinst
            echo "${TERMUXSHEBANG}" >> src/${linuxtype}/${pkgname}_${versiondeb}_${archtype}/DEBIAN/prerm
            echo -e "Package: ${pkgname}\nVersion: ${versiondeb}\nArchitecture: ${archtype}\nMaintainer: ${username} <${useremail}>\nDepends: ${depend}\nInstalled-Size: ${installsize}\nHomepage: ${homepage}\nDescription: ${description}" >> src/${linuxtype}/${pkgname}_${versiondeb}_${archtype}/DEBIAN/control
        else
            mkdir -p src/${linuxtype}/${pkgname}_${versiondeb}_${archtype}/usr/local/bin
            echo "${DEBIANSHEBANG}" >> src/${linuxtype}/${pkgname}_${versiondeb}_${archtype}/DEBIAN/postinst
            echo "${DEBIANSHEBANG}" >> src/${linuxtype}/${pkgname}_${versiondeb}_${archtype}/DEBIAN/prerm
            echo -e "Package: ${pkgname}\nVersion: ${versiondeb}\nArchitecture: ${archtype}\nMaintainer: ${username} <${useremail}>\nDepends: ${depend}\nInstalled-Size: ${installsize}\nHomepage: ${homepage}\nDescription: ${description}" >> src/${linuxtype}/${pkgname}_${versiondeb}_${archtype}/DEBIAN/control
        fi
        chmod 755 src/${linuxtype}/${pkgname}_${versiondeb}_${archtype}/DEBIAN -R
        echo -e "Run: nano src/${linuxtype}/${pkgname}_${versiondeb}_${archtype}/usr/local/bin/(your binary)\nOr move binary to this folder"
    else
        exit
    fi
}

function update_source() {
    read -p "OS Type: " linuxtype;
    files=$(ls -1 src/$linuxtype)
    select choice in ${files[@]}; do
        break
    done
    read -p "New Name: " pkgname;
    read -p "Old Version: " oldversion;
    read -p "New Version: " newversion;
    read -p "Architecture: " archtype;
    mv src/${linuxtype}/${choice} src/${linuxtype}/${pkgname}_${newversion}_${archtype}
    sed -i "s/${oldversion}/${newversion}/" src/${linuxtype}/${pkgname}_${newversion}_${archtype}/DEBIAN/control
    if grep -q "${oldversion}" src/${linuxtype}/${pkgname}_${newversion}_${archtype}/usr/local/bin/*; then
        sed -i "s/${oldversion}/${newversion}/" src/${linuxtype}/${pkgname}_${newversion}_${archtype}/usr/local/bin/*
    fi
    chmod 755 src/${linuxtype}/${pkgname}_${newversion}_${archtype}/DEBIAN -R
}

function show_help() {
    echo -e "Build Deb

Usage: build-deb [command]
                 [options]
Command:
        source         : Create packages
        start          : Build deb from packages

Options:
        -h, --help     : Show this help
        -v, --version  : Show the Version

try: [git-repo -h] to build github repository

for more info visit: https://github.com/ArieSR91
"
}

function show_version() {
    echo "1.7.8-SR"
}

case $1 in
    start)
        build_deb
        ;;
    source)
        build_source
        ;;
    update)
        update_source
        ;;
    -v | --version)
        show_version
        ;;
    -h | --help | *)
        show_help
        ;;
esac
