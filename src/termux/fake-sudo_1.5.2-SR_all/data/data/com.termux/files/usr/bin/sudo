#!/data/data/com.termux/files/usr/bin/bash

home_var='/data/data/com.termux/files/'

if [[ $USER == "" ]]; then
    export USER=$(whoami)
fi

show_help(){
    echo -e "\e[1mFake sudo 0.4-SR"
    echo -e "sudo <command> [options]\n"
    echo -e "Options:\n"
    echo -e "         -h, --help    : Show this help and exit"
    echo -e "         -v, --version : Show the version"
    echo -e "\nDefault password: termux\nYou can change it on \$PREFIX/etc/sudoers\n\nfor more information visit https://github.com/ArieSR91\n"
    return 0
}

cat_pass=$(cat $home_var'usr/etc/sudoers' | grep -w $USER | head -n1)

if [[ $cat_pass == '' ]]; then
    echo -e "The user ${USER} is not in sudoers group."
    exit 2
fi

PASSWD=$cat_pass

if [[ $1 != '' ]] && [[ $1 != "-"* ]]; then
    if [[ $PASSWD == 'root|All|'* ]]; then
        check_config=$(cat $home_var'usr/etc/sudoers.d/sudo-exec.conf')
        if [[ $check_config == "exec_as_root: false" ]]; then
            command $@
        else
            command su -c $@
        fi
        exit
    fi
    if [ ! -f $PREFIX/tmp/password.conf ]; then
        touch $PREFIX/tmp/password.conf
    else
        source $PREFIX/tmp/password.conf
    fi
    if [ ! -f $HOME/.bash_logout ]; then
        touch $HOME/.bash_logout
    fi
    if ! grep -q "PREFIX" $HOME/.bash_logout; then
        echo -e "rm \$PREFIX/tmp/password.conf" >> $HOME/.bash_logout
    fi
    if grep -q "PASSWORD" $PREFIX/tmp/password.conf; then
        password=${PASSWORD}
    else
        read -s -p '[sudo] password for '${USER}': ' password; echo ""
        if grep -q "${password}" $home_var'usr/etc/sudoers' ; then
            echo "PASSWORD=$password" >> $PREFIX/tmp/password.conf
        fi
    fi
    processed_data=$USER'|All|'$password
    if [[ $processed_data == $PASSWD ]]; then
        check_config=$(cat $home_var'usr/etc/sudoers.d/sudo-exec.conf')
        if [[ $check_config == "exec_as_root: false" ]]; then
            if [[ $1 == "su" ]]; then
                proot -0 $(which bash)
            else
                command $@
            fi
        else
            command su -c $@
        fi
    else
        echo -e 'Sorry, try again.'
        $0 $@
        exit
    fi
else
    case $1 in
        -h | --help)
            show_help;
            ;;
        -v | --version)
            echo -e "1.5.2-SR"
            ;;
        * )
            show_help;
            ;;
    esac
fi
