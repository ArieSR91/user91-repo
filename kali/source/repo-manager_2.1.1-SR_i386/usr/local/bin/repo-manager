#!/bin/bash

if [ ! -d $HOME/Project ]; then
    mkdir -p $HOME/Project/debian
    mkdir $HOME/Project/termux
    ## Termux
    if [ ! -d $HOME/Project/termux-deb ]; then
        mkdir -p $HOME/Project/termux-deb
    else
        if [ ! -d $HOME/Project/termux-deb/main ]; then
            mkdir -p $HOME/Project/termux-deb/main
        fi
    fi
    ## Debian Based
    if [ ! -d $HOME/Project/debian-deb ]; then
        mkdir -p $HOME/Project/debian-deb
    else
        if [ ! -d $HOME/Project/debian-deb/main ]; then
            mkdir -p $HOME/Project/debian-deb/main
        fi
    fi
fi

function generate_source() {
    build-deb source
}

function generate_deb() {
    build-deb start
}

function generate_repo() {
    git-repo build
}

function push_repo() {
    git-repo push
}

function update_source() {
    build-deb update
}

function show_help() {
    echo -e "Repository Manager by Arie-SR91
Goto your repository folder and run the command

Usage: repo-manager [options]

Options:
         -s, --source         : Build source of deb
         -d, --deb            : Build deb from source
         -r, --repo           : Build repository tree
         -p. --push           : Push repository to Github
         -u, --update         : Update source package version
         -h, --help           : Show this help screen
         -v, --version        : Show the version

Manual: build-deb -h
        build-repo -h
        git-repo -h

for more info visit: https://github.com/ArieSR91
"
}

function show_version() {
    echo "2.1.1-SR"
}

case $1 in
    -s | --source)
        generate_source
        ;;
    -d | --deb)
        generate_deb
        ;;
    -r | --repo)
        generate_repo
        ;;
    -p | --push)
        push_repo
        ;;
    -u | --update)
        update_source
        ;;
    -v | --version)
        show_version
        ;;
    -h | --help | *)
        show_help
        ;;
esac
