#!/bin/bash
## normal color
black='\033[0;30;47m'
red='\033[0;31m'
green='\033[0;32m'
yellow='\033[0;33m'
blue='\033[0;34m'
purple='\033[0;35m'
cyan='\033[0;36m'
white='\033[0;37m'
## bold color
blackbold='\033[1;30m'
redbold='\033[1;31m'
greenbold='\033[1;32m'
yellowbold='\033[1;33m'
bluebold='\033[1;34m'
purplebold='\033[1;35m'
cyanbold='\033[1;36m'
whitebold='\033[1;37m'

COMMAND=$@
cd /opt/seeker
python3 seeker $COMMAND
